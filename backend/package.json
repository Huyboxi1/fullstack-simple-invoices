{
  "name": "simple-invoice-be",
  "version": "1.0.0",
  "description": "demo simple backend service",
  "author": "hugodo",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "start": "npx ts-node --transpile-only src/main.ts",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest --detectOpenHandles --forceExit",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typeorm": "node --require ts-node/register ./node_modules/typeorm/cli.js",
    "migration:run": "npm run typeorm -- migration:run",
    "seed": "npx ts-node --transpile-only src/database/seed/seed.ts"
  },
  "dependencies": {
    "@nestjs/axios": "0.0.2",
    "@nestjs/common": "8.0.11",
    "@nestjs/config": "1.0.2",
    "@nestjs/core": "8.0.11",
    "@nestjs/jwt": "^8.0.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "8.0.11",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "5.1.0",
    "@nestjs/terminus": "10.2.3",
    "@nestjs/throttler": "2.0.0",
    "@nestjs/typeorm": "8.0.2",
    "axios": "0.21.4",
    "bcrypt": "^6.0.0",
    "bcryptjs": "2.4.3",
    "class-transformer": "0.3.1",
    "class-validator": "0.14.0",
    "compression": "1.7.4",
    "dotenv": "10.0.0",
    "express-timeout-handler": "^2.2.2",
    "faker": "5.5.3",
    "hash-stream": "1.2.0",
    "helmet": "4.6.0",
    "https-proxy-agent": "^7.0.6",
    "into-stream": "6.0.0",
    "jimp": "0.16.1",
    "joi": "17.4.0",
    "lodash": "4.17.21",
    "mjml": "4.10.1",
    "moment": "^2.30.1",
    "nest-winston": "^1.9.7",
    "nestjs-typeorm-paginate": "2.6.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "8.3.0",
    "querystring": "0.2.0",
    "reflect-metadata": "0.1.13",
    "rimraf": "3.0.2",
    "rxjs": "7.4.0",
    "swagger-ui-express": "4.1.6",
    "typeorm": "0.2.36",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "4.5.0"
  },
  "devDependencies": {
    "@babel/runtime": "7.14.6",
    "@nestjs/cli": "8.1.4",
    "@nestjs/schematics": "7.0.0",
    "@nestjs/testing": "8.0.11",
    "@types/archiver": "5.1.0",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "2.4.2",
    "@types/cache-manager": "3.4.2",
    "@types/compression": "1.7.0",
    "@types/dotenv": "8.2.3",
    "@types/express": "4.17.3",
    "@types/faker": "5.5.3",
    "@types/glob": "8.1.0",
    "@types/hash-stream": "1.2.0",
    "@types/jest": "^30.0.0",
    "@types/jimp": "0.2.28",
    "@types/lodash": "4.14.159",
    "@types/mjml": "4.7.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "13.9.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/request-promise": "4.1.47",
    "@types/sanitize-html": "1.27.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/parser": "8.1.0",
    "auto-changelog": "2.3.0",
    "jest": "27.2.5",
    "lint-staged": "10.4.1",
    "micromatch": "4.0.4",
    "prettier": "1.19.1",
    "supertest": "^4.0.2",
    "ts-jest": "27.0.5",
    "ts-loader": "9.2.6",
    "ts-node": "10.2.1",
    "typescript": "4.9.5",
    "uuidv4": "6.2.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".spec.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "@/(.*)$": "<rootDir>/$1"
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
